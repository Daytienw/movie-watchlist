{
  "info": {
    "name": "Movie Watchlist API",
    "description": "Collection for the movie-watchlist Spring Boot project: auth (signup/login with JWT), user info, OMDb-backed movie lookup, and watchlist CRUD.\n\nRun \"Login\" first (or \"Signup\" then \"Login\") — it auto-saves the JWT into the `token` collection variable, which every other request uses via Bearer auth.\n\nKnown issues surfaced while mapping the API (useful context when a request fails):\n- `POST /api/watchlist/` currently 500s: the service never sets `status`/`addedDate`/`user` on the new item, and those columns are NOT NULL.\n- `/api/movie` (singular) requires a JWT even though `SecurityConfig` permits `/api/movies/**` (plural) — the paths don't match, so auth is effectively required.\n- `GET /api/watchlist/{id}` and `PUT`/`DELETE` on a missing id return 500 instead of 404 (unhandled `NoSuchElementException`/`RuntimeException`).\n- Signup/`/api/users/*` responses return the raw `User` entity, including the bcrypt password hash.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "watchlistId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"P@ssw0rd123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Registers a new user. Returns the raw User entity (currently includes the bcrypt password hash)."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.token) {",
                  "        pm.collectionVariables.set('token', body.token);",
                  "        console.log('Saved JWT to {{token}} collection variable');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"P@ssw0rd123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Logs in and returns { token, expiresIn }. The test script auto-saves the token into the {{token}} collection variable for use by all other requests."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Requires Bearer JWT. Returns the raw User entity for the authenticated user."
          },
          "response": []
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", ""]
            },
            "description": "Requires Bearer JWT. Returns an array of raw User entities."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Search Movie by Title",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/movie?title=Inception",
              "host": ["{{baseUrl}}"],
              "path": ["api", "movie"],
              "query": [
                { "key": "title", "value": "Inception" }
              ]
            },
            "description": "Looks up a movie by title via OMDb. `title` query param is required (missing it returns 400). Despite SecurityConfig permitting `/api/movies/**`, this controller is mapped to the singular `/api/movie`, so in practice a Bearer JWT is required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Watchlist",
      "item": [
        {
          "name": "Create Watchlist Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.id) {",
                  "        pm.collectionVariables.set('watchlistId', body.id);",
                  "        console.log('Saved watchlist id to {{watchlistId}}');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imdbId\": \"tt1375666\",\n  \"title\": \"Inception\",\n  \"year\": \"2010\",\n  \"poster\": \"https://example.com/poster.jpg\",\n  \"status\": \"PLANNED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", ""]
            },
            "description": "Requires Bearer JWT. NOTE: as currently implemented, WatchlistService.create() does not set status/addedDate/user on the new entity, and those columns are NOT NULL — this request is expected to 500 until that's fixed."
          },
          "response": []
        },
        {
          "name": "List Watchlist Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", ""]
            },
            "description": "Requires Bearer JWT. Returns ALL watchlist items in the DB (not currently scoped to the authenticated user)."
          },
          "response": []
        },
        {
          "name": "Get Watchlist Item by Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/{{watchlistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", "{{watchlistId}}"]
            },
            "description": "Requires Bearer JWT. Returns 500 (not 404) if the id doesn't exist."
          },
          "response": []
        },
        {
          "name": "Update Watchlist Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imdbId\": \"tt1375666\",\n  \"title\": \"Inception\",\n  \"year\": \"2010\",\n  \"poster\": \"https://example.com/poster.jpg\",\n  \"status\": \"WATCHED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/{{watchlistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", "{{watchlistId}}"]
            },
            "description": "Requires Bearer JWT. Returns 500 (not 404) if the id doesn't exist."
          },
          "response": []
        },
        {
          "name": "Delete Watchlist Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/watchlist/{{watchlistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "watchlist", "{{watchlistId}}"]
            },
            "description": "Requires Bearer JWT. Returns 204 on success; 500 (not 404) if the id doesn't exist."
          },
          "response": []
        }
      ]
    }
  ]
}
